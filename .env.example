# Quantum Analyzer Streamlit UI environment

# Directory containing artifacts:
# artifact_bundle.json, summary.json, equity_curve.csv, actions.csv,
# templates.json or templates.parquet, optional doctor_report.json
ARTIFACT_DIR=./artifacts

# Solana RPC endpoint (Helius or standard Solana RPC)
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# Optional wallet for read-only inspection
BENCHMARK_WALLET=

# Persistent UI data (manual execution journal sqlite)
UI_DATA_DIR=./ui_data
